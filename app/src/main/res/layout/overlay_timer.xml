<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Estado colapsado: píldora con countdown (clon de la cápsula) -->
    <LinearLayout
        android:id="@+id/overlay_collapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/overlay_pill_bg"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/overlay_collapsed_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_stat_timer"
            android:contentDescription="@null" />

        <Chronometer
            android:id="@+id/overlay_collapsed_chrono"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_mono_semibold" />
    </LinearLayout>

    <!-- Estado expandido: tarjeta con countdown grande + info + botones -->
    <LinearLayout
        android:id="@+id/overlay_expanded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@drawable/overlay_card_bg"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <Chronometer
            android:id="@+id/overlay_expanded_chrono"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_mono_semibold" />

        <TextView
            android:id="@+id/overlay_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/overlay_btn_cancel"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="28dp"
                android:background="@drawable/overlay_btn_bg"
                android:src="@drawable/ic_notif_close"
                android:scaleType="centerInside"
                android:contentDescription="@null" />

            <ImageButton
                android:id="@+id/overlay_btn_pause"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/overlay_btn_bg"
                android:src="@drawable/ic_notif_pause"
                android:scaleType="centerInside"
                android:contentDescription="@null" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
