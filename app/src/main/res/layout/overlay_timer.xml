<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Estado colapsado: cápsula que SOLO muestra el countdown, ubicada debajo
         de la barra de estado para no interferir con el sistema. El anillo de la
         cámara es ahora una ventana independiente (overlay_ring.xml). -->
    <FrameLayout
        android:id="@+id/overlay_collapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/overlay_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/overlay_pill_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <Chronometer
                android:id="@+id/overlay_collapsed_chrono"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/jetbrains_mono_semibold" />
        </LinearLayout>
    </FrameLayout>

    <!-- Estado expandido: tarjeta con countdown grande + info + botones.
         minWidth fuerza un aspecto más rectangular (más ancho que alto). -->
    <LinearLayout
        android:id="@+id/overlay_expanded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@drawable/overlay_card_bg"
        android:minWidth="340dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <Chronometer
            android:id="@+id/overlay_expanded_chrono"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_mono_semibold" />

        <TextView
            android:id="@+id/overlay_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/overlay_btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:background="@drawable/overlay_btn_text_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minWidth="110dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlay_btn_pause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/overlay_btn_text_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minWidth="110dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
